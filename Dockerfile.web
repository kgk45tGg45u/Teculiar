# ─── Build stage ─────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder
WORKDIR /app

# Hosted dashboards (admin + client). The browser now calls the same-origin `/api` (served by Apache
# next to the dashboards), so NEXT_PUBLIC_API_URL is no longer baked into the browser bundle. It is
# kept as an OPTIONAL server-side fallback (single-tenant mode); server SSR prefers API_INTERNAL_URL
# at runtime. Pass via --build-arg only if you rely on the fallback.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# assetPrefix MUST be baked at BUILD time. With `output: standalone`, Next freezes the config into
# required-server-files.json and the standalone server ignores a runtime DASHBOARD_ASSET_PREFIX — so the
# bundles would ship at /_next/... and 404 behind Apache's /_dash strip. The hosted dashboards image is
# ALWAYS served behind that strip (tenant subdomains AND white-label buyer domains, where the storefront
# owns /_next), so bake /_dash here. Overridable via --build-arg for the single-tenant legacy build.
ARG DASHBOARD_ASSET_PREFIX=/_dash
ENV DASHBOARD_ASSET_PREFIX=$DASHBOARD_ASSET_PREFIX

# Copy workspace manifests first — lets Docker cache the install layer
COPY package.json package-lock.json ./
COPY packages/shared/package.json   ./packages/shared/
COPY packages/locales/package.json  ./packages/locales/
COPY packages/web-core/package.json ./packages/web-core/
COPY apps/web/package.json          ./apps/web/
RUN npm ci

# Copy source code
COPY tsconfig.base.json  ./
COPY packages/shared     ./packages/shared
# apps/web resolves @teculiar/locales and @teculiar/web-core straight from their .ts/.tsx source via the
# tsconfig path mappings, so the source (locales JSON packs + manifest; web-core lib/components) must be
# present for Turbopack to bundle it into the standalone output.
COPY packages/locales    ./packages/locales
COPY packages/web-core   ./packages/web-core
COPY apps/web            ./apps/web

# Build shared lib → build Next.js app (produces .next/standalone)
RUN npm run build --workspace @teculiar/shared
RUN npm run build --workspace @teculiar/web

# ─── Production stage ─────────────────────────────────────────────────────────
FROM node:24-alpine AS production
WORKDIR /app

ENV NODE_ENV=production
# next/server reads PORT and HOSTNAME at runtime
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# The standalone bundle includes a minimal Node server and all traced deps.
# outputFileTracingRoot=monorepo-root means the bundle is rooted at /app,
# and the entry point is apps/web/server.js.
COPY --from=builder /app/apps/web/.next/standalone       ./
COPY --from=builder /app/apps/web/.next/static           ./apps/web/.next/static
COPY --from=builder /app/apps/web/public                 ./apps/web/public

EXPOSE 3000

CMD ["node", "apps/web/server.js"]
