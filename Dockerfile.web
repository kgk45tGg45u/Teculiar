# ─── Build stage ─────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder
WORKDIR /app

# NEXT_PUBLIC_API_URL must be baked in at build time (used by the browser bundle).
# Pass it via --build-arg or as a Docker build secret.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Copy workspace manifests first — lets Docker cache the install layer
COPY package.json package-lock.json ./
COPY packages/shared/package.json ./packages/shared/
COPY apps/web/package.json         ./apps/web/
RUN npm ci

# Copy source code
COPY tsconfig.base.json  ./
COPY packages/shared     ./packages/shared
COPY apps/web            ./apps/web

# Build shared lib → build Next.js app (produces .next/standalone)
RUN npm run build --workspace @dezhost/shared
RUN npm run build --workspace @dezhost/web

# ─── Production stage ─────────────────────────────────────────────────────────
FROM node:24-alpine AS production
WORKDIR /app

ENV NODE_ENV=production
# next/server reads PORT and HOSTNAME at runtime
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# The standalone bundle includes a minimal Node server and all traced deps.
# outputFileTracingRoot=monorepo-root means the bundle is rooted at /app,
# and the entry point is apps/web/server.js.
COPY --from=builder /app/apps/web/.next/standalone       ./
COPY --from=builder /app/apps/web/.next/static           ./apps/web/.next/static
COPY --from=builder /app/apps/web/public                 ./apps/web/public

EXPOSE 3000

CMD ["node", "apps/web/server.js"]
