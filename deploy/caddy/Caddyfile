# Teculiar edge — Caddy (Phase 4.6d, topology B1: Caddy on eu01's SECOND IP).
#
# Apache keeps the FIRST IP :443 (Virtualmin hosting customers + the current teculiar.net/.com/dezhost.com
# vhosts). Caddy binds the SECOND IP :443 and terminates TLS for tenant domains whose DNS points at it.
# Caddy preserves the client Host header by default, so the API resolves the tenant from `tenant_domains`
# exactly as through Apache.
#
# ⚠️ Untested template — run `caddy validate --config Caddyfile` and test on teculiar.com BEFORE dezhost.com.
# Replace 203.0.113.2 with eu01's real second IPv4 (or use the IPv6). Container ports match /opt/teculiar
# (.env): API 4001, dashboards 3010, teculiar storefront 3011, dezhost storefront 3021.

{
	# Bind every site below to the second IP so Apache keeps the first IP untouched.
	default_bind 203.0.113.2

	# On-demand TLS for UNKNOWN (external customer) hosts: before issuing a cert, ask the API whether the
	# host is a registered ACTIVE tenant domain. Only a 2xx allows issuance → the edge never mints certs for
	# arbitrary hostnames pointed at this IP (anti-abuse + Let's-Encrypt-quota gate). Named sites below get
	# their certs the normal way and do not hit this.
	on_demand_tls {
		ask http://127.0.0.1:4001/api/v1/tenancy/tls-allowed
		interval 2m
		burst 5
	}
}

# Shared routing for a tenant APEX host that serves storefront + /admin + /client + /api by path.
# Arg {args[0]} = that tenant's storefront container port.
(tenant_apex_routes) {
	# API + uploads → the API container (Host preserved → tenant resolved from tenant_domains).
	handle /api/*     { reverse_proxy 127.0.0.1:4001 }
	handle /uploads/* { reverse_proxy 127.0.0.1:4001 }

	# Dashboards (admin + client + login + reset) → the dashboards container.
	handle /admin*          { reverse_proxy 127.0.0.1:3010 }
	handle /client*         { reverse_proxy 127.0.0.1:3010 }
	handle /login*          { reverse_proxy 127.0.0.1:3010 }
	handle /reset-password* { reverse_proxy 127.0.0.1:3010 }

	# Dashboard bundles: assetPrefix=/_dash → strip back to the dashboards' real /_next (handle_path strips).
	handle_path /_dash/* { reverse_proxy 127.0.0.1:3010 }

	# Everything else → this tenant's storefront container.
	handle { reverse_proxy 127.0.0.1:{args[0]} }
}

# ── Own domains (Part L dogfood): named sites, normal auto-HTTPS, explicit storefront port ──
teculiar.com, www.teculiar.com {
	import tenant_apex_routes 3011
}

dezhost.com, www.dezhost.com {
	import tenant_apex_routes 3021
}

# ── External customer custom domains (dynamic, on-demand TLS) ───────────────────────────────────────────
# TODO(before onboarding the first external customer): finalize the hosting model (open decision O-2 +
# apexMode). Two shapes:
#   • Self-hosted storefront (install-script): only admin.<domain>/client.<domain>/api.<domain> point HERE;
#     the apex storefront runs on the customer's own box. Route api.* → :4001, admin.*/client.* → :3010.
#   • Hosted storefront: the apex points here too and needs a per-tenant (or Host-multiplexed) storefront
#     container — not yet built. Until then, external tenants use a `*.teculiar.net` subdomain or self-host.
# Example (self-hosted-storefront shape), enable when the model is chosen:
#
# *.<matches any registered host via on_demand ask> {
# 	tls { on_demand }
# 	@api    header_regexp Host ^api\.
# 	@admin  header_regexp Host ^admin\.
# 	@client header_regexp Host ^client\.
# 	handle @api    { reverse_proxy 127.0.0.1:4001 }
# 	handle @admin  { reverse_proxy 127.0.0.1:3010 }   # dashboards serve /admin — confirm the URL/asset story
# 	handle @client { reverse_proxy 127.0.0.1:3010 }
# }
