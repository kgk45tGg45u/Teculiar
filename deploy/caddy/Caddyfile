# Teculiar edge — Caddy (Phase 4.6d, topology B1: Caddy on eu01's floating IP, Apache keeps the primary IP).
#
# Apache stays on the PRIMARY IP :80/:443 (all Virtualmin hosting customers + the own-domain Apache
# bootstrap + their Let's Encrypt). Caddy binds ONLY the FLOATING IP and terminates TLS for Teculiar
# tenant domains whose DNS points at it. Caddy preserves the client Host header by default, so the API
# resolves the tenant from `tenant_domains` exactly as through Apache.
#
# EVERY site here uses on-demand TLS: Caddy attempts NO certificates at startup — a cert is only issued
# when a TLS handshake actually arrives at the floating IP AND the API's tls-allowed endpoint approves the
# hostname. So this config is completely inert for a domain until you point its DNS at the floating IP.
#
# ⚠️ Run `sudo caddy validate --config /etc/caddy/Caddyfile` after every edit. Full runbook: ./README.md.
# Container ports match /opt/teculiar/.env: API 4001, dashboards 3010, teculiar storefront 3011,
# dezhost storefront 3021.
#
# {$TECULIAR_BACKEND_HOST:127.0.0.1}: on the one-box setup the containers are local (default). If Caddy
# later moves to a dedicated edge box (README Part 5), set TECULIAR_BACKEND_HOST=<eu01 private IP> via
# `systemctl edit caddy` → [Service] Environment=... — same file, no other change.
{
	# Bind ONLY the floating IP (195.201.252.12) so Apache keeps the primary IP untouched.
	default_bind 195.201.252.12

	# On-demand TLS gate: before issuing a cert for a hostname, ask the API whether it is a registered
	# ACTIVE tenant domain (tenant_domains). Only a 2xx allows issuance → the edge never mints certs for
	# arbitrary hostnames pointed at this IP (anti-abuse + Let's-Encrypt-quota protection).
	on_demand_tls {
		ask http://{$TECULIAR_BACKEND_HOST:127.0.0.1}:4001/api/v1/tenancy/tls-allowed
	}
}

# Shared routing for a tenant APEX host that serves storefront + /admin + /client + /api by path.
# Arg {args[0]} = that tenant's storefront container port.
# (Caddyfile syntax: a `{` must end its line — no one-line blocks.)
(tenant_apex_routes) {
	tls {
		on_demand
	}

	# API + uploads → the API container (Host preserved → tenant resolved from tenant_domains).
	handle /api/* {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:4001
	}
	handle /uploads/* {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:4001
	}

	# Dashboards (admin + client + login + reset) → the dashboards container.
	handle /admin* {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:3010
	}
	handle /client* {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:3010
	}
	handle /login* {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:3010
	}
	handle /reset-password* {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:3010
	}

	# Dashboard bundles: assetPrefix=/_dash → strip back to the dashboards' real /_next (handle_path strips).
	handle_path /_dash/* {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:3010
	}

	# Everything else → this tenant's storefront container.
	handle {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:{args[0]}
	}
}

# ── Smoke test (README Part 1, step 7): proves on-demand TLS + routing end-to-end WITHOUT touching any
# live domain. Needs: (a) DNS A record edge-test.teculiar.net → the floating IP (overrides the wildcard),
# (b) `register-domain.js edge-test.teculiar.net teculiar apex active`. Then browse it. Remove or keep —
# it is inert while its DNS/registration are absent.
edge-test.teculiar.net {
	import tenant_apex_routes 3011
}

# ── Own domains (Part L dogfood): DORMANT until their DNS is repointed at the floating IP — on-demand TLS
# means no startup issuance, so these blocks are safe to keep while Apache still serves the domains.
# ⚠️ Before flipping DNS for the www hosts, also register them:
#    register-domain.js www.teculiar.com teculiar apex active   (and www.dezhost.com dezhost apex active)
teculiar.com, www.teculiar.com {
	import tenant_apex_routes 3011
}

dezhost.com, www.dezhost.com {
	import tenant_apex_routes 3021
}

# ── External customer custom domains (dynamic, on-demand TLS; O-3 = SELF-HOSTED storefront) ─────────────
# The customer's APEX storefront runs on THEIR box (install script); only their per-surface subdomains
# point here: api.<domain> (whole host = the API), admin.<domain> (hosted admin), and the CLIENT area on
# a subdomain whose label the tenant chooses ("client", "portal", "kunde", … — anything not api./admin.).
# Every host must be a registered ACTIVE tenant_domains row (the on_demand ask gate enforces it, and the
# API resolves the tenant from the Host). Named sites above always win over this catch-all.
https:// {
	tls {
		on_demand
	}

	# api.<domain> — the whole host is the hosted API (the self-hosted storefront's same-domain API base).
	@apiHost header_regexp Host "^api\."
	handle @apiHost {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:4001
	}

	# Clean URLs (Phase 2.1): a per-surface host serves its dashboard section at the HOST ROOT — the
	# browser URL never shows the /admin or /client segment. INTERNAL rewrites (not redirects) prefix the
	# path before proxying; already-prefixed paths (app redirects, legacy links) pass through untouched,
	# so both URL styles keep working until the app emits surface-relative links (Phase 2.2).
	#
	# admin.<domain> → /admin/<path>. Root rewrites to exactly /admin (a trailing slash would make Next's
	# 308 slash-redirect leak the segment into the URL bar). /reset-password + /sso (handoff callback)
	# live at the app ROOT, and API/asset/wellknown paths must reach their own handlers — all excluded.
	@adminRoot {
		header_regexp Host "^admin\."
		path /
	}
	rewrite @adminRoot /admin

	@adminSurface {
		header_regexp Host "^admin\."
		not path / /admin* /reset-password* /sso* /api/* /uploads/* /og/* /_dash/* /_next/* /favicon.ico /robots.txt /sitemap.xml /.well-known/*
	}
	rewrite @adminSurface /admin{uri}

	# Any other label (tenant-chosen client area: client./portal./kunde./…) → /client/<path>. The client
	# login, reset + /sso pages live at the app root — kept unprefixed.
	@clientRoot {
		not header_regexp Host "^(api|admin)\."
		path /
	}
	rewrite @clientRoot /client

	@clientSurface {
		not header_regexp Host "^(api|admin)\."
		not path / /client* /admin* /login* /reset-password* /sso* /api/* /uploads/* /og/* /_dash/* /_next/* /favicon.ico /robots.txt /sitemap.xml /.well-known/*
	}
	rewrite @clientSurface /client{uri}

	# Dashboard pages call their own origin: /api + /uploads go to the API (Host preserved → tenant).
	@dashApi path /api/* /uploads/*
	handle @dashApi {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:4001
	}

	# Dashboard bundles (assetPrefix /_dash) — strip back to the app's real /_next.
	handle_path /_dash/* {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:3010
	}

	# Everything else on any registered host → the hosted dashboards (white-label). The TLS gate already
	# guarantees only registered ACTIVE tenant hosts ever get this far.
	handle {
		reverse_proxy {$TECULIAR_BACKEND_HOST:127.0.0.1}:3010
	}
}
