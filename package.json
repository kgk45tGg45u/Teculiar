{
  "name": "dezhost-hosting-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Production-grade SaaS platform foundation for a German hosting and IT services provider.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace @dezhost/web run dev",
    "dev:api": "npm --workspace @dezhost/api run start:dev",
    "dev:full": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report tests/e2e/results/html",
    "build": "npm --workspaces run build",
    "lint": "npm --workspaces run lint",
    "test": "npm --workspace @dezhost/api run test",
    "typecheck": "npm --workspaces run typecheck",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/platform-express": "11.1.19",
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.2.1",
    "prisma": "^6.19.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "file-type": "^22.0.1",
    "multer": "^2.1.1",
    "postcss": "^8.5.13",
    "rxjs": "^7.8.2"
  },
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.0.0"
  }
}
