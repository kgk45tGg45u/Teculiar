{
  "compilerOptions": {
    "target": "ES2022",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@teculiar/shared": ["packages/shared/src/index.ts"],
      "@teculiar/shared/*": ["packages/shared/src/*"],
      "@teculiar/locales": ["packages/locales/index.ts"],
      "@teculiar/locales/*": ["packages/locales/*"],
      "@teculiar/web-core": ["packages/web-core/src/index.ts"],
      "@teculiar/web-core/*": ["packages/web-core/src/*"]
    }
  }
}
