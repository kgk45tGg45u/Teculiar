generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Retained only for blog/announcement content (Announcement.locale, Translation.targetLocale),
// which is still de/en (deferred to a later phase). User/Invoice/Content/EmailTemplate locales
// are now free-form String so admin-added languages can be stored; values are validated in app code.
enum Locale {
  de
  en
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum TeamMemberRole {
  OWNER
  BILLING
  TECHNICAL
  VIEWER
}

enum ContactType {
  BILLING
  TECHNICAL
  DOMAIN
  LEGAL
}

enum ProductType {
  SHARED_HOSTING
  DOMAIN
  VPS
  DEDICATED_SERVER
  NEXTCLOUD
  CRM_SERVER
  MANAGED_SERVICE
  SUPPORT_SUBSCRIPTION
}

enum BillingCycle {
  ONE_TIME
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  YEAR_1
  YEAR_2
  YEAR_3
  YEAR_4
  YEAR_5
  YEAR_6
  YEAR_7
  YEAR_8
  YEAR_9
  YEAR_10
}

enum ServiceStatus {
  PENDING
  PROVISIONING
  ACTIVE
  SUSPENDED
  CANCELLED
  TERMINATED
  FAILED
  PROVISIONING_FAILED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethodType {
  CREDIT_CARD
  PAYPAL
  SEPA
  CRYPTO
  ACCOUNT_BALANCE
  BANK_TRANSFER
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING
  PROVISIONING
  COMPLETE
  FAILED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  PROVISIONING
  ACTIVE
  FAILED
  SKIPPED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  PENDING_CANCEL
  CANCELLED
  FAILED
}

enum CouponType {
  FIXED
  PERCENTAGE
}

enum TicketStatus {
  OPEN
  ANSWERED
  CUSTOMER_REPLY
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ContentType {
  PAGE
  POST
  LEGAL
}

enum TranslationStatus {
  AI_DRAFT
  MANUAL_OVERRIDE
  REVIEWED
  PUBLISHED
}

enum DomainStatus {
  PENDING
  PENDING_TRANSFER
  ACTIVE
  TRANSFERRING
  EXPIRED
  LOCKED
  SUSPENDED
  CANCELLED
  FAILED
}

enum GdprRequestType {
  EXPORT
  DELETE
}

enum GdprRequestStatus {
  QUEUED
  PROCESSING
  COMPLETED
  REJECTED
}

model User {
  id              String           @id @default(cuid())
  customerNumber  Int              @unique @default(autoincrement())
  email           String           @unique
  passwordHash    String
  name            String
  locale          String           @default("de")
  customerType    CustomerType     @default(INDIVIDUAL)
  countryCode     String           @default("DE")
  vatId           String?
  balanceCents    Int              @default(0)
  segment         String           @default("standard")
  avatarUrl       String?
  isGuest         Boolean          @default(false)
  totpSecret      String?
  totpEnabled     Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userRoles       UserRole[]
  teams           TeamMember[]
  contacts        Contact[]
  refreshSessions RefreshSession[]
  paymentMethods  PaymentMethod[]
  orders          Order[]
  services        Service[]
  invoices        Invoice[]
  subscriptions   Subscription[]
  domainRecords   DomainRecord[]
  tickets         Ticket[]         @relation("TicketOwner")
  assignedTickets Ticket[]         @relation("TicketAssignee")
  ticketReplies   TicketReply[]
  internalNotes   TicketInternalNote[]
  departmentMemberships DepartmentMember[]
  knowledgebaseArticles KnowledgebaseArticle[]
  contents        Content[]
  announcements   Announcement[]
  announcementReads AnnouncementRead[]
  emailLogs       EmailLog[]
  affiliate       Affiliate?
  gdprRequests    GdprRequest[]
  auditLogs       AuditLog[]
}

model Role {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  userRoles   UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
}

model Permission {
  id          String           @id @default(cuid())
  action      String
  subject     String
  roles       RolePermission[]

  @@unique([action, subject])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model RefreshSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  ipAddress String?
  userAgent String?   @db.Text
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id           String       @id @default(cuid())
  name         String
  countryCode  String       @default("DE")
  vatId        String?
  billingEmail String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  members      TeamMember[]
  contacts     Contact[]
  paymentMethods PaymentMethod[]
  services     Service[]
  invoices     Invoice[]
  subscriptions Subscription[]
  emailLogs    EmailLog[]
}

model TeamMember {
  id        String         @id @default(cuid())
  teamId    String
  userId    String
  role      TeamMemberRole @default(VIEWER)
  createdAt DateTime       @default(now())
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Contact {
  id        String      @id @default(cuid())
  userId    String?
  teamId    String?
  type      ContactType
  name      String
  email     String
  phone     String?
  address   Json?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?       @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  teamId    String?
  to        String
  subject   String   @db.Text
  template  String?
  status    String
  payload   Json?
  sentAt    DateTime?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
}

model Product {
  id          String          @id @default(cuid())
  categoryId  String?
  name        String
  slug        String          @unique
  type        ProductType
  description String          @db.Text
  active      Boolean         @default(true)
  homepageVisible Boolean     @default(true)
  provisioningModule String?
  domainRequirement String     @default("NOT_NEEDED")
  freeDomainBillingCycle String?
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  category    ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  prices      ProductPrice[]
  configs     ProductConfig[]
  addOns      ProductAddOn[]
  orderItems  OrderItem[]
  services    Service[]

  @@index([categoryId])
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  provisioningModule String?
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model ProductPrice {
  id            String       @id @default(cuid())
  productId     String
  billingCycle  BillingCycle
  amountCents   Int
  setupFeeCents Int          @default(0)
  currency      String       @default("EUR")
  active        Boolean      @default(true)
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  services      Service[]
  subscriptions Subscription[]

  @@unique([productId, billingCycle])
}

model DomainTldPrice {
  id          String   @id @default(cuid())
  tld         String
  action      String
  years       Int
  amountCents Int
  currency    String   @default("EUR")
  manual      Boolean  @default(false)
  suggested   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tld, action, years])
  @@index([tld])
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      String        @unique @default(cuid())
  userId           String
  invoiceId        String?       @unique
  status           OrderStatus   @default(PENDING)
  subtotalCents    Int
  setupFeeCents    Int           @default(0)
  taxAmountCents   Int           @default(0)
  totalCents       Int
  currency         String        @default("EUR")
  paymentMethod    PaymentMethodType?
  customerSnapshot Json          @default("{}")
  placedAt         DateTime      @default(now())
  paidAt           DateTime?
  completedAt      DateTime?
  notes            String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  items            OrderItem[]
}

model OrderItem {
  id                String          @id @default(cuid())
  orderId           String
  productId         String?
  productPriceId    String
  serviceId         String?
  type              ProductType
  description       String          @db.Text
  productSnapshot   Json?
  domainName        String?
  billingCycle      BillingCycle
  quantity          Int             @default(1)
  unitAmountCents   Int
  setupFeeCents     Int             @default(0)
  totalCents        Int
  configuration     Json            @default("{}")
  provisioningStatus OrderItemStatus @default(PENDING)
  provider          String?
  providerReference String?
  providerPayload   Json?
  errorMessage      String?         @db.Text
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  productPrice      ProductPrice    @relation(fields: [productPriceId], references: [id], onDelete: Restrict)
  service           Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  invoiceItems      InvoiceItem[]
  domainRecords     DomainRecord[]
}

model ProductConfig {
  id        String  @id @default(cuid())
  productId String
  key       String
  label     String
  values    Json
  required  Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
}

model AddOn {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?        @db.Text
  amountCents   Int
  setupFeeCents Int            @default(0)
  billingCycle  BillingCycle?
  recurring     Boolean        @default(true)
  productLinks  ProductAddOn[]
  serviceLinks  ServiceAddOn[]
}

model ProductAddOn {
  id        String  @id @default(cuid())
  productId String
  addOnId   String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  addOn     AddOn   @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@unique([productId, addOnId])
}

model Service {
  id             String          @id @default(cuid())
  userId         String
  teamId         String?
  orderId        String?
  orderItemId    String?
  initialInvoiceId String?
  domainRecordId String?
  productId      String?
  productPriceId String
  status         ServiceStatus   @default(PENDING)
  billingCycle   BillingCycle?
  recurringAmountCents Int       @default(0)
  setupFeeCents  Int             @default(0)
  configuration  Json            @default("{}")
  customFields   Json            @default("{}")
  productSnapshot Json?
  externalId     String?
  moduleName     String?
  moduleStatus   String          @default("pending")
  moduleReference String?
  autoRenew      Boolean         @default(true)
  startedAt      DateTime?
  renewsAt       DateTime?
  nextDueAt      DateTime?
  suspendedAt    DateTime?
  cancelAt       DateTime?
  cancelledAt    DateTime?
  terminatedAt   DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  team           Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  product        Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  productPrice   ProductPrice    @relation(fields: [productPriceId], references: [id])
  serviceAddOns  ServiceAddOn[]
  orderItems     OrderItem[]
  subscriptions  Subscription[]
  invoiceItems   InvoiceItem[]
  tickets        Ticket[]
  domainRecords  DomainRecord[]
  hostingService HostingService?
  serverInstance ServerInstance?
}

model ServiceAddOn {
  id        String  @id @default(cuid())
  serviceId String
  addOnId   String
  quantity  Int     @default(1)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  addOn     AddOn   @relation(fields: [addOnId], references: [id])

  @@unique([serviceId, addOnId])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique @default(cuid())
  tempInvoiceNumber String?     @unique
  finalInvoiceNumber String?    @unique
  finalizedAt     DateTime?
  userId          String
  teamId          String?
  subscriptionId  String?
  status          InvoiceStatus @default(PENDING)
  issuedAt        DateTime      @default(now())
  dueAt           DateTime
  paidAt          DateTime?
  subtotalCents   Int
  discountCents   Int           @default(0)
  taxAmountCents  Int           @default(0)
  totalCents      Int
  currency        String        @default("EUR")
  locale          String        @default("de")
  reverseCharge   Boolean       @default(false)
  taxReason       String?       @db.Text
  customerSnapshot Json         @default("{}")
  sellerSnapshot  Json          @default("{}")
  footerLines     Json          @default("[]")
  orderSnapshot   Json          @default("{}")
  adminNotes      String?       @db.Text
  couponId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  team            Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  coupon          Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  order           Order?
  items           InvoiceItem[]
  transactions    Transaction[]
  ticketMessages  TicketReply[]
}

model InvoiceItem {
  id                 String    @id @default(cuid())
  invoiceId          String
  type               String    @default("CUSTOM")
  orderItemId        String?
  serviceId          String?
  domainRecordId     String?
  lifecycleAction    String?
  billingCycle       BillingCycle?
  description        String    @db.Text
  quantity           Int       @default(1)
  unitAmountCents    Int
  subtotalCents      Int
  discountCents      Int       @default(0)
  taxRate            Int
  taxAmountCents     Int
  totalCents         Int
  servicePeriodStart DateTime?
  servicePeriodEnd   DateTime?
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now())
  invoice            Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  orderItem          OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  service            Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  domainRecord       DomainRecord? @relation(fields: [domainRecordId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([serviceId])
  @@index([domainRecordId])
}

model Transaction {
  id                String            @id @default(cuid())
  invoiceId         String
  method            PaymentMethodType
  status            TransactionStatus
  amountCents       Int
  currency          String            @default("EUR")
  providerReference String            @unique
  raw               Json?
  createdAt         DateTime          @default(now())
  invoice           Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  teamId         String?
  serviceId      String
  productPriceId String
  billingCycle   BillingCycle
  status         SubscriptionStatus @default(ACTIVE)
  nextInvoiceAt  DateTime
  lastInvoiceAt  DateTime?
  couponId       String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  team           Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  service        Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  productPrice   ProductPrice       @relation(fields: [productPriceId], references: [id])
  coupon         Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  invoices       Invoice[]
}

model PaymentMethod {
  id            String            @id @default(cuid())
  userId        String
  teamId        String?
  type          PaymentMethodType
  label         String
  provider      String
  providerToken String
  providerCustomerId String?
  mandateId     String?
  status        String            @default("PENDING")
  automatic     Boolean           @default(true)
  default       Boolean           @default(false)
  verifiedAt    DateTime?
  consentGivenAt DateTime?
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  team          Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId, automatic, status])
}

model Coupon {
  id             String         @id @default(cuid())
  code           String         @unique
  type           CouponType
  amountCents    Int            @default(0)
  percent        Int            @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  maxRedemptions Int?
  redeemedCount  Int            @default(0)
  active         Boolean        @default(true)
  invoices       Invoice[]
  subscriptions  Subscription[]
}

model Affiliate {
  id                String              @id @default(cuid())
  userId            String              @unique
  code              String              @unique
  commissionPercent Int                 @default(10)
  active            Boolean             @default(true)
  createdAt         DateTime            @default(now())
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals         AffiliateReferral[]
}

model AffiliateReferral {
  id          String    @id @default(cuid())
  affiliateId String
  referredUserId String
  invoiceId   String?
  commissionCents Int  @default(0)
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
}

model DomainRecord {
  id                String       @id @default(cuid())
  serviceId         String?
  userId            String
  orderId           String?
  orderItemId       String?
  initialInvoiceId  String?
  domain            String       @unique
  type              String       @default("register")
  status            DomainStatus @default(PENDING)
  registrarProvider String       @default("resell.biz")
  registrarModule   String?
  externalId        String?
  authCodeHash      String?
  eppCode           String?
  expiresAt         DateTime?
  registrationDate  DateTime?
  nextDueAt         DateTime?
  registrationPeriodYears Int    @default(1)
  firstPaymentAmountCents Int    @default(0)
  recurringAmountCents Int       @default(0)
  autoRenew         Boolean      @default(true)
  nameservers       Json?
  dnsRecords        Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  service           Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItem         OrderItem?   @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  invoiceItems      InvoiceItem[]

  @@index([orderItemId])
  @@index([initialInvoiceId])
}

model ModuleLog {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  invoiceId      String?
  orderId        String?
  orderItemId    String?
  serviceId      String?
  domainRecordId String?
  moduleName     String
  action         String
  status         String
  request        Json     @default("{}")
  response       Json     @default("{}")
  errorMessage   String?   @db.Text
  actorId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([invoiceId])
  @@index([serviceId])
  @@index([domainRecordId])
  @@index([action, serviceId])
  @@index([action, domainRecordId])
}

model HostingService {
  id            String  @id @default(cuid())
  serviceId     String  @unique
  panel         String
  primaryDomain String?
  phpVersion    String?
  diskLimitMb   Int?
  mailboxLimit  Int?
  backupPolicy  String?
  service       Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model ServerInstance {
  id          String  @id @default(cuid())
  serviceId   String  @unique
  provider    String
  datacenter  String  @default("DE")
  hostname    String?
  ipv4        String?
  ipv6        String?
  cpu         String?
  ramMb       Int?
  diskGb      Int?
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Department {
  id            String             @id @default(cuid())
  slug          String             @unique
  name          String
  email         String?
  color         String?
  active        Boolean            @default(true)
  isDefault     Boolean            @default(false)
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  members       DepartmentMember[]
  tickets       Ticket[]
  cannedReplies CannedReply[]
}

model DepartmentMember {
  id           String     @id @default(cuid())
  departmentId String
  userId       String
  createdAt    DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([userId])
}

model Ticket {
  id            String             @id @default(cuid())
  publicId      String             @unique
  userId        String
  serviceId     String?
  assigneeId    String?
  departmentId  String
  status        TicketStatus       @default(OPEN)
  priority      TicketPriority     @default(NORMAL)
  subject       String
  paid          Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation("TicketOwner", fields: [userId], references: [id], onDelete: Cascade)
  assignee      User?              @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  department    Department         @relation(fields: [departmentId], references: [id])
  service       Service?           @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  replies       TicketReply[]
  internalNotes TicketInternalNote[]
  attachments   TicketAttachment[]

  @@index([departmentId])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  body      String   @db.Text
  internal  Boolean  @default(false)
  system    Boolean  @default(false)
  invoiceId String?
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  attachments TicketAttachment[]

  @@index([invoiceId])
}

model TicketInternalNote {
