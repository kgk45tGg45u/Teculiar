generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  de
  en
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum TeamMemberRole {
  OWNER
  BILLING
  TECHNICAL
  VIEWER
}

enum ContactType {
  BILLING
  TECHNICAL
  DOMAIN
  LEGAL
}

enum ProductType {
  SHARED_HOSTING
  DOMAIN
  VPS
  DEDICATED_SERVER
  NEXTCLOUD
  CRM_SERVER
  MANAGED_SERVICE
  SUPPORT_SUBSCRIPTION
}

enum BillingCycle {
  ONE_TIME
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  YEAR_1
  YEAR_2
  YEAR_3
  YEAR_4
  YEAR_5
  YEAR_6
  YEAR_7
  YEAR_8
  YEAR_9
  YEAR_10
}

enum ServiceStatus {
  PENDING
  ORDERED
  PROVISIONING
  ACTIVE
  SUSPENDED
  PENDING_CANCEL
  CANCELLED
  TERMINATED
  FAILED
  PROVISIONING_FAILED
}

enum InvoiceStatus {
  DRAFT
  UNSENT
  PENDING
  UNPAID
  PAID
  OVERDUE
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethodType {
  CREDIT_CARD
  PAYPAL
  SEPA
  CRYPTO
  ACCOUNT_BALANCE
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROVISIONING
  COMPLETE
  FAILED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  PROVISIONING
  ACTIVE
  FAILED
  SKIPPED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  PENDING_CANCEL
  CANCELLED
  FAILED
}

enum CouponType {
  FIXED
  PERCENTAGE
}

enum TicketDepartment {
  SALES
  SUPPORT
  ABUSE
}

enum TicketStatus {
  NEW
  OPEN
  WAITING_ON_CLIENT
  WAITING_ON_STAFF
  ANSWERED
  CUSTOMER_REPLY
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ContentType {
  PAGE
  POST
  LEGAL
}

enum TranslationStatus {
  AI_DRAFT
  MANUAL_OVERRIDE
  REVIEWED
  PUBLISHED
}

enum DomainStatus {
  PENDING
  PENDING_TRANSFER
  ACTIVE
  TRANSFERRING
  EXPIRED
  LOCKED
  SUSPENDED
  CANCELLED
  FAILED
}

enum GdprRequestType {
  EXPORT
  DELETE
}

enum GdprRequestStatus {
  QUEUED
  PROCESSING
  COMPLETED
  REJECTED
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  name            String
  locale          Locale           @default(de)
  customerType    CustomerType     @default(INDIVIDUAL)
  countryCode     String           @default("DE")
  vatId           String?
  balanceCents    Int              @default(0)
  segment         String           @default("standard")
  totpSecret      String?
  totpEnabled     Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userRoles       UserRole[]
  teams           TeamMember[]
  contacts        Contact[]
  refreshSessions RefreshSession[]
  paymentMethods  PaymentMethod[]
  orders          Order[]
  services        Service[]
  invoices        Invoice[]
  subscriptions   Subscription[]
  domainRecords   DomainRecord[]
  tickets         Ticket[]         @relation("TicketOwner")
  assignedTickets Ticket[]         @relation("TicketAssignee")
  ticketReplies   TicketReply[]
  internalNotes   TicketInternalNote[]
  knowledgebaseArticles KnowledgebaseArticle[]
  contents        Content[]
  announcements   Announcement[]
  announcementReads AnnouncementRead[]
  emailLogs       EmailLog[]
  affiliate       Affiliate?
  gdprRequests    GdprRequest[]
  auditLogs       AuditLog[]
}

model Role {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  userRoles   UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
}

model Permission {
  id          String           @id @default(cuid())
  action      String
  subject     String
  roles       RolePermission[]

  @@unique([action, subject])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model RefreshSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id           String       @id @default(cuid())
  name         String
  countryCode  String       @default("DE")
  vatId        String?
  billingEmail String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  members      TeamMember[]
  contacts     Contact[]
  paymentMethods PaymentMethod[]
  services     Service[]
  invoices     Invoice[]
  subscriptions Subscription[]
  emailLogs    EmailLog[]
}

model TeamMember {
  id        String         @id @default(cuid())
  teamId    String
  userId    String
  role      TeamMemberRole @default(VIEWER)
  createdAt DateTime       @default(now())
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Contact {
  id        String      @id @default(cuid())
  userId    String?
  teamId    String?
  type      ContactType
  name      String
  email     String
  phone     String?
  address   Json?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?       @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  teamId    String?
  to        String
  subject   String
  template  String?
  status    String
  payload   Json?
  sentAt    DateTime?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
}

model Product {
  id          String          @id @default(cuid())
  categoryId  String?
  name        String
  slug        String          @unique
  type        ProductType
  description String
  active      Boolean         @default(true)
  homepageVisible Boolean     @default(true)
  provisioningModule String?
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  category    ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  prices      ProductPrice[]
  configs     ProductConfig[]
  addOns      ProductAddOn[]
  orderItems  OrderItem[]
  services    Service[]

  @@index([categoryId])
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  provisioningModule String?
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model ProductPrice {
  id            String       @id @default(cuid())
  productId     String
  billingCycle  BillingCycle
  amountCents   Int
  setupFeeCents Int          @default(0)
  currency      String       @default("EUR")
  active        Boolean      @default(true)
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  services      Service[]
  subscriptions Subscription[]

  @@unique([productId, billingCycle])
}

model DomainTldPrice {
  id          String   @id @default(cuid())
  tld         String
  action      String
  years       Int
  amountCents Int
  currency    String   @default("EUR")
  manual      Boolean  @default(false)
  suggested   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tld, action, years])
  @@index([tld])
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      String        @unique @default(cuid())
  userId           String
  invoiceId        String?       @unique
  status           OrderStatus   @default(PENDING_PAYMENT)
  subtotalCents    Int
  setupFeeCents    Int           @default(0)
  taxAmountCents   Int           @default(0)
  totalCents       Int
  currency         String        @default("EUR")
  paymentMethod    PaymentMethodType?
  customerSnapshot Json          @default("{}")
  placedAt         DateTime      @default(now())
  paidAt           DateTime?
  completedAt      DateTime?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  items            OrderItem[]
}

model OrderItem {
  id                String          @id @default(cuid())
  orderId           String
  productId         String
  productPriceId    String
  serviceId         String?
  type              ProductType
  description       String
  domainName        String?
  billingCycle      BillingCycle
  quantity          Int             @default(1)
  unitAmountCents   Int
  setupFeeCents     Int             @default(0)
  totalCents        Int
  configuration     Json            @default("{}")
  provisioningStatus OrderItemStatus @default(PENDING)
  provider          String?
  providerReference String?
  providerPayload   Json?
  errorMessage      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  productPrice      ProductPrice    @relation(fields: [productPriceId], references: [id], onDelete: Restrict)
  service           Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  invoiceItems      InvoiceItem[]
  domainRecords     DomainRecord[]
}

model ProductConfig {
  id        String  @id @default(cuid())
  productId String
  key       String
  label     String
  values    Json
  required  Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
}

model AddOn {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  amountCents   Int
  setupFeeCents Int            @default(0)
  billingCycle  BillingCycle?
  recurring     Boolean        @default(true)
  productLinks  ProductAddOn[]
  serviceLinks  ServiceAddOn[]
}

model ProductAddOn {
  id        String  @id @default(cuid())
  productId String
  addOnId   String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  addOn     AddOn   @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@unique([productId, addOnId])
}

model Service {
  id             String          @id @default(cuid())
  userId         String
  teamId         String?
  orderId        String?
  orderItemId    String?
  initialInvoiceId String?
  domainRecordId String?
  productId      String
  productPriceId String
  status         ServiceStatus   @default(ORDERED)
  billingCycle   BillingCycle?
  recurringAmountCents Int       @default(0)
  setupFeeCents  Int             @default(0)
  configuration  Json            @default("{}")
  customFields   Json            @default("{}")
  externalId     String?
  moduleName     String?
  moduleStatus   String          @default("pending")
  moduleReference String?
  autoRenew      Boolean         @default(true)
  startedAt      DateTime?
  renewsAt       DateTime?
  nextDueAt      DateTime?
  suspendedAt    DateTime?
  cancelAt       DateTime?
  cancelledAt    DateTime?
  terminatedAt   DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  team           Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  product        Product         @relation(fields: [productId], references: [id])
  productPrice   ProductPrice    @relation(fields: [productPriceId], references: [id])
  serviceAddOns  ServiceAddOn[]
  orderItems     OrderItem[]
  subscriptions  Subscription[]
  invoiceItems   InvoiceItem[]
  tickets        Ticket[]
  domainRecords  DomainRecord[]
  hostingService HostingService?
  serverInstance ServerInstance?
}

model ServiceAddOn {
  id        String  @id @default(cuid())
  serviceId String
  addOnId   String
  quantity  Int     @default(1)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  addOn     AddOn   @relation(fields: [addOnId], references: [id])

  @@unique([serviceId, addOnId])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique @default(cuid())
  tempInvoiceNumber String?     @unique
  finalInvoiceNumber String?    @unique
  finalizedAt     DateTime?
  userId          String
  teamId          String?
  subscriptionId  String?
  status          InvoiceStatus @default(DRAFT)
  issuedAt        DateTime      @default(now())
  dueAt           DateTime
  paidAt          DateTime?
  subtotalCents   Int
  discountCents   Int           @default(0)
  taxAmountCents  Int           @default(0)
  totalCents      Int
  currency        String        @default("EUR")
  reverseCharge   Boolean       @default(false)
  taxReason       String?
  customerSnapshot Json         @default("{}")
  sellerSnapshot  Json          @default("{}")
  footerLines     Json          @default("[]")
  orderSnapshot   Json          @default("{}")
  adminNotes      String?
  couponId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  team            Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  coupon          Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  order           Order?
  items           InvoiceItem[]
  transactions    Transaction[]
}

model InvoiceItem {
  id                 String    @id @default(cuid())
  invoiceId          String
  type               String    @default("CUSTOM")
  orderItemId        String?
  serviceId          String?
  domainRecordId     String?
  lifecycleAction    String?
  billingCycle       BillingCycle?
  description        String
  quantity           Int       @default(1)
  unitAmountCents    Int
  subtotalCents      Int
  discountCents      Int       @default(0)
  taxRate            Int
  taxAmountCents     Int
  totalCents         Int
  servicePeriodStart DateTime?
  servicePeriodEnd   DateTime?
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now())
  invoice            Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  orderItem          OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  service            Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  domainRecord       DomainRecord? @relation(fields: [domainRecordId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([serviceId])
  @@index([domainRecordId])
}

model Transaction {
  id                String            @id @default(cuid())
  invoiceId         String
  method            PaymentMethodType
  status            TransactionStatus
  amountCents       Int
  currency          String            @default("EUR")
  providerReference String            @unique
  raw               Json?
  createdAt         DateTime          @default(now())
  invoice           Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  teamId         String?
  serviceId      String
  productPriceId String
  billingCycle   BillingCycle
  status         SubscriptionStatus @default(ACTIVE)
  nextInvoiceAt  DateTime
  lastInvoiceAt  DateTime?
  couponId       String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  team           Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  service        Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  productPrice   ProductPrice       @relation(fields: [productPriceId], references: [id])
  coupon         Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  invoices       Invoice[]
}

model PaymentMethod {
  id            String            @id @default(cuid())
  userId        String
  teamId        String?
  type          PaymentMethodType
  label         String
  provider      String
  providerToken String
  providerCustomerId String?
  mandateId     String?
  status        String            @default("PENDING")
  automatic     Boolean           @default(true)
  default       Boolean           @default(false)
  verifiedAt    DateTime?
  consentGivenAt DateTime?
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  team          Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId, automatic, status])
}

model Coupon {
  id             String         @id @default(cuid())
  code           String         @unique
  type           CouponType
  amountCents    Int            @default(0)
  percent        Int            @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  maxRedemptions Int?
  redeemedCount  Int            @default(0)
  active         Boolean        @default(true)
  invoices       Invoice[]
  subscriptions  Subscription[]
}

model Affiliate {
  id                String              @id @default(cuid())
  userId            String              @unique
  code              String              @unique
  commissionPercent Int                 @default(10)
  active            Boolean             @default(true)
  createdAt         DateTime            @default(now())
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals         AffiliateReferral[]
}

model AffiliateReferral {
  id          String    @id @default(cuid())
  affiliateId String
  referredUserId String
  invoiceId   String?
  commissionCents Int  @default(0)
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
}

model DomainRecord {
  id                String       @id @default(cuid())
  serviceId         String?
  userId            String
  orderId           String?
  orderItemId       String?
  initialInvoiceId  String?
  domain            String       @unique
  type              String       @default("register")
  status            DomainStatus @default(PENDING)
  registrarProvider String       @default("resell.biz")
  registrarModule   String?
  externalId        String?
  authCodeHash      String?
  eppCode           String?
  expiresAt         DateTime?
  registrationDate  DateTime?
  nextDueAt         DateTime?
  registrationPeriodYears Int    @default(1)
  firstPaymentAmountCents Int    @default(0)
  recurringAmountCents Int       @default(0)
  autoRenew         Boolean      @default(true)
  nameservers       Json?
  dnsRecords        Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  service           Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItem         OrderItem?   @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  invoiceItems      InvoiceItem[]

  @@index([orderItemId])
  @@index([initialInvoiceId])
}

model ModuleLog {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  invoiceId      String?
  orderId        String?
  orderItemId    String?
  serviceId      String?
  domainRecordId String?
  moduleName     String
  action         String
  status         String
  request        Json     @default("{}")
  response       Json     @default("{}")
  errorMessage   String?
  actorId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([invoiceId])
  @@index([serviceId])
  @@index([domainRecordId])
  @@index([action, serviceId])
  @@index([action, domainRecordId])
}

model HostingService {
  id            String  @id @default(cuid())
  serviceId     String  @unique
  panel         String
  primaryDomain String?
  phpVersion    String?
  diskLimitMb   Int?
  mailboxLimit  Int?
  backupPolicy  String?
  service       Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model ServerInstance {
  id          String  @id @default(cuid())
  serviceId   String  @unique
  provider    String
  datacenter  String  @default("DE")
  hostname    String?
  ipv4        String?
  ipv6        String?
  cpu         String?
  ramMb       Int?
  diskGb      Int?
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Ticket {
  id            String             @id @default(cuid())
  publicId      String             @unique
  userId        String
  serviceId     String?
  assigneeId    String?
  department    TicketDepartment
  status        TicketStatus       @default(NEW)
  priority      TicketPriority     @default(NORMAL)
  subject       String
  paid          Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation("TicketOwner", fields: [userId], references: [id], onDelete: Cascade)
  assignee      User?              @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  service       Service?           @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  replies       TicketReply[]
  internalNotes TicketInternalNote[]
  attachments   TicketAttachment[]
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  body      String
  internal  Boolean  @default(false)
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments TicketAttachment[]
}

model TicketInternalNote {
  id        String   @id @default(cuid())
  ticketId  String
  staffId   String
  body      String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  staff     User     @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model TicketAttachment {
  id         String   @id @default(cuid())
  ticketId   String
  replyId    String?
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  reply      TicketReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([replyId])
}

model CannedReply {
  id         String           @id @default(cuid())
  department TicketDepartment
  title      String
  body       String
  active     Boolean          @default(true)
  createdAt  DateTime         @default(now())
}

model KnowledgebaseArticle {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  excerpt        String?
  body           String
  keywords       String[] @default([])
  images         Json     @default("[]")
  published      Boolean  @default(true)
  seoTitle       String?
  seoDescription String?
  authorId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  author         User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([published, updatedAt])
}

model Content {
  id             String        @id @default(cuid())
  type           ContentType
  slug           String
  locale         Locale
  title          String
  excerpt        String?
  content        Json
  seoTitle       String?
  seoDescription String?
  authorId       String
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  author         User          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  translations   Translation[]

  @@unique([type, locale, slug])
}

model Announcement {
  id          String             @id @default(cuid())
  locale      Locale             @default(de)
  title       String
  excerpt     String?
  body        String
  authorId    String
  publishedAt DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  author      User               @relation(fields: [authorId], references: [id], onDelete: Restrict)
  reads       AnnouncementRead[]

  @@index([locale, publishedAt])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  hiddenAt       DateTime?
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId, hiddenAt])
}

model Translation {
  id              String            @id @default(cuid())
  sourceContentId String
  targetLocale    Locale
  title           String
  content         Json
  seoTitle        String?
  seoDescription  String?
  status          TranslationStatus @default(AI_DRAFT)
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  sourceContent   Content           @relation(fields: [sourceContentId], references: [id], onDelete: Cascade)

  @@unique([sourceContentId, targetLocale])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String
  locale    Locale
  subject   String
  body      String
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
}

model TaxRule {
  id          String   @id @default(cuid())
  countryCode String
  rate        Int
  reverseChargeEligible Boolean @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model PaymentProcessorConfig {
  id        String            @id @default(cuid())
  method    PaymentMethodType @unique
  enabled   Boolean           @default(false)
  config    Json
  updatedAt DateTime          @updatedAt
}

model CookieConsent {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String?
  categories Json
  ipHash     String?
  createdAt  DateTime @default(now())
}

model GdprRequest {
  id        String            @id @default(cuid())
  userId    String
  type      GdprRequestType
  status    GdprRequestStatus @default(QUEUED)
  resultKey String?
  createdAt DateTime          @default(now())
  closedAt  DateTime?
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  subject   String
  subjectId String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}
