{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "./src",
    "outDir": "./dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "noEmit": false,
    "paths": {
      "@teculiar/shared": ["packages/shared/dist/index.d.ts"],
      "@teculiar/shared/*": ["packages/shared/dist/*"],
      "@teculiar/locales": ["packages/locales/dist/index.d.ts"],
      "@teculiar/locales/*": ["packages/locales/dist/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
