  "cron": {
    "whatHeading": "What the Cron Does",
    "intro": "The cron runner is triggered by an external HTTP request. Each call checks which jobs are due and runs them. Jobs are throttled — they only execute after their configured interval has passed.",
    "heartbeatHtml": "Every trigger also writes a <code>cron.started</code> heartbeat and a <code>cron.completed</code> summary (with duration and per-job results), so you can confirm the cron is actually reaching the server. A wrong or missing secret is recorded as <code>cron.unauthorized</code>. See all of these under <a href=\"/admin/logs\">Settings → Logs</a> in the <strong>Cron logs</strong> tab.",
    "activateHeading": "How to Activate the Cron on Your Server",
    "activateIntroHtml": "The cron is triggered by a POST (or GET) request to <code>/api/v1/cron?token=YOUR_SECRET</code>. Set up a system cron job on your server to call this endpoint on your preferred interval (e.g. hourly):",
    "replaceSecretHtml": "Replace <code>YOUR_SECRET</code> with the Cron Secret set below (the optional <code>CRON_SECRET</code> server env var is also accepted) and use your own domain. <strong> Use the www host.</strong> A request to the bare domain (<code>dezhost.com</code>) is redirected to <code>www.dezhost.com</code>; a plain <code>curl</code> does not follow the redirect, so the request is dropped and the cron silently does nothing. You can also trigger it manually using the \"Run Cron Now\" button below.",
    "freq": {
      "domainPrices": "Every 24 h (configurable)",
      "domainExpirations": "Every 12 h (configurable)",
      "domainStatuses": "Every 15 min (configurable)",
      "hostingStatuses": "Every 15 min (configurable)",
      "billingMaintenance": "Every cron run",
      "invoiceReminders": "Once per day",
      "ticketsClose": "Every cron run",
      "mailboxes": "Every 5 min (configurable)",
      "sitemap": "Once per day",
      "aiBlogPost": "Every 8 h (configurable)"
    },
    "desc": {
      "domainPrices": "Syncs TLD pricing from Resell.biz into the domain price list.",
      "domainExpirations": "Refreshes expiry dates for all registered domains.",
      "domainStatuses": "Checks and updates domain registration statuses.",
      "hostingStatuses": "Checks Virtualmin hosting account statuses.",
      "billingMaintenance": "Generates upcoming invoices, marks overdue invoices, and runs subscription renewals.",
      "invoiceReminders": "Sends payment reminder emails to clients with invoices due within the configured days.",
      "ticketsClose": "Auto-closes tickets that have been answered and have had no reply for the configured hours.",
      "mailboxes": "Polls the support &amp; sales IMAP mailboxes. Every fetched email is logged (with subject and matched client) and converted into a ticket; mail from an unknown sender creates a guest contact so nothing is lost. IMAP connection/login errors are recorded in the cron log.",
      "sitemap": "Reports the live sitemap shape (URL counts) to the log. <code>/sitemap.xml</code> is served live by the website using the <strong>Site URL</strong> from Settings and the current published posts — no file is written, so it is always up to date.",
      "aiBlogPost": "Generates an AI blog post when AI blogging is enabled and a Deepseek API key is set."
    }
  },
